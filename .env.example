# QR Menü — ortam değişkenleri şablonu
# Kopyala: .env.local (geliştirme) / .env.production (sunucu, chmod 600)

# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_URL=https://<project-ref>.supabase.co
# Yalnız server tarafında kullanılır (api route + admin actions) — client'a SIZMAZ
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Analitik session hash günlük salt'ı (cookie'siz KVKK-dostu hash) — rastgele 40+ karakter
ANALYTICS_SALT_SECRET=<random-secret>
# Manuel revalidation endpoint sırrı (POST /api/revalidate) — rastgele 40+ karakter
REVALIDATE_SECRET=<random-secret>

# Görsel upload kök dizini
# Geliştirme: <repo>/.uploads-dev — Prod: <home>/domains/<domain>/public_html/uploads
UPLOADS_DIR=

APP_BASE_URL=http://localhost:3000
TZ=Europe/Istanbul

# scripts/db-query.mjs için (opsiyonel — Supabase Management API)
# SUPABASE_ACCESS_TOKEN=sbp_...
# SUPABASE_PROJECT_REF=<project-ref>
