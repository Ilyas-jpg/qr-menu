# ============================================================
# QR Menü — public_html/.htaccess (Passenger + güvenlik + cache)
# PLZ Palazoğlu'nun kanıtlanmış deseninden uyarlandı.
# {{APP_ROOT}} deploy script'i tarafından doldurulur.
# ============================================================

PassengerNodejs /opt/alt/alt-nodejs20/root/usr/bin/node
PassengerAppType node
PassengerAppRoot {{APP_ROOT}}
PassengerStartupFile start.js
PassengerAppEnv production
PassengerFriendlyErrorPages off

# --- Güvenlik başlıkları ---
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # CSP: Supabase REST + Realtime websocket; font/style self-host (next/font)
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://{{SUPABASE_HOST}} wss://{{SUPABASE_HOST}}; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
  Header always set Cross-Origin-Opener-Policy "same-origin"
</IfModule>

# --- Cache: content-hash'li statikler + upload görselleri 1 yıl immutable ---
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpg|jpeg|png|avif|gif|svg|ico|woff|woff2|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# --- Sıkıştırma ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json image/svg+xml font/woff2
</IfModule>

# --- Dizin listeleme kapalı ---
Options -Indexes

# --- Hostinger Passenger :3000 Location sızıntısı düzeltmesi (PLZ dersi) ---
<IfModule mod_headers.c>
  Header edit Location ":3000" ""
</IfModule>
